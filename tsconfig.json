    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src/scripts/**/*.js"],
    "exclude": ["node_modules", "dist"]
}
