{
    "name": "rahul-biswas-portfolio",
    "version": "1.0.0",
    "description": "Optimized developer portfolio with real-time ASCII backgrounds.",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "node build.js",
        "preview": "vite preview",
        "deploy": "wrangler pages deploy dist --branch main",
        "lint": "eslint src/scripts --ext .js",
        "format": "prettier --check src/",
        "format:fix": "prettier --write src/",
        "typecheck": "tsc --noEmit --checkJs"
    },
    "devDependencies": {
        "@vitejs/plugin-legacy": "^8.1.0",
        "eslint": "^10.6.0",
        "prettier": "^3.9.1",
        "terser": "^5.31.1",
        "typescript": "^6.0.3",
        "vite": "^8.1.0",
        "wrangler": "^4.105.0"
    }
}
